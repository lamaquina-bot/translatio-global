---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import ProcessTimeline from '../../components/ProcessTimeline.astro';
import ContactForm from '../../components/ContactForm.astro';
import ChatbotWidget from '../../components/ChatbotWidget.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
---

<BaseLayout title="Home" lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} />
  <main>
    <Hero lang={lang} />
    <ServiceCards lang={lang} />
    <ProcessTimeline lang={lang} />
    <section class="py-16 px-4 bg-[#4A7C6F] text-white">
      <div class="max-w-4xl mx-auto grid grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-2">+500</div>
          <div class="text-white/80">Families</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-2">15+</div>
          <div class="text-white/80">Years</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-2">5</div>
          <div class="text-white/80">Languages</div>
        </div>
      </div>
    </section>
    <section class="py-16 px-4 text-center bg-white">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Take the First Step?</h2>
        <p class="text-gray-600 mb-8">Request a free consultation. No commitment, no pressure.</p>
        <a href="#contact" class="inline-block bg-[#D4A574] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#c4945f] transition-colors">
          Request Free Consultation
        </a>
      </div>
    </section>
    <ContactForm lang={lang} />
  </main>
  <Footer lang={lang} />
  <ChatbotWidget lang={lang} />
</BaseLayout>
