---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Translatio Global - Acompañamiento integral en subrogación gestacional en Colombia', lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    <title>{title} | Translatio Global</title>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "pending"}'></script>
  </head>
  <body class="bg-[#FAFAF7] text-[#2D2D2D] font-['Inter',sans-serif] leading-relaxed">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #4A7C6F;
    --color-secondary: #D4A574;
    --color-accent: #2C5F8A;
    --color-bg: #FAFAF7;
    --color-text: #2D2D2D;
  }

  [lang="zh"] {
    font-family: 'Noto Sans SC', 'Inter', sans-serif !important;
  }

  h1, h2, h3 {
    font-family: 'Playfair Display', Georgia, serif;
  }

  [lang="zh"] h1, [lang="zh"] h2, [lang="zh"] h3 {
    font-family: 'Noto Sans SC', sans-serif !important;
  }
</style>
